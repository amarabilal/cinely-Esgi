# ─────────────────────────────────────────────
# CINELY — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer .env dans git
# ─────────────────────────────────────────────

# ── Base de données PostgreSQL ────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=notesdb
DB_USER=notesuser
DB_PASSWORD=changeme_strong_password

# ── Redis ─────────────────────────────────────
# En dev Docker Compose, REDIS_HOST est injecté automatiquement (=redis)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=changeme_redis_password

# ── JWT ───────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_ACCESS_SECRET=changeme_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars_long

# ── Application ───────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:3000

# ── Mail (dev : Mailhog sur port 1025) ────────
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=

# ── IA — Embeddings & recherche sémantique ───
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# https://platform.openai.com
OPENAI_API_KEY=sk-proj-...

# ── Google OAuth ─────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/callback

# ── Stripe (mode test uniquement) ────────────
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# https://dashboard.stripe.com/test/products
STRIPE_PRICE_ID=price_...
STRIPE_PLAN_NAME=Cinely Pro

# ── Monitoring (optionnel en dev) ─────────────
# GlitchTip / Sentry — laisser vide pour désactiver
SENTRY_DSN=

# ─────────────────────────────────────────────
# FRONTEND — Variables Vite (préfixe VITE_ obligatoire)
# Créer apps/frontend/.env avec ces variables si besoin en dev standalone
# En Docker Compose, VITE_API_BASE_URL est injecté automatiquement
# ─────────────────────────────────────────────
# VITE_API_BASE_URL=http://localhost:3000
# VITE_SENTRY_DSN=                        # optionnel
# VITE_MATOMO_URL=                        # optionnel
# VITE_ENABLE_PUSH=false                  # notifications push (expérimental)
