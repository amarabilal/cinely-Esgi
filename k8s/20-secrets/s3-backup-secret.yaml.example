apiVersion: v1
kind: Secret
metadata:
  name: s3-backup-secret
  namespace: cluster-project
type: Opaque
data:
  # OVH Object Storage — région eu-west-par (Paris)
  # Créer les credentials dans OVH Manager : Public Cloud → Utilisateurs → Générer les identifiants S3
  # Encoder en base64 : echo -n "valeur" | base64
  S3_ENDPOINT: <base64_encoded_ovh_s3_endpoint>   # https://s3.eu-west-par.io.cloud.ovh.net
  S3_BUCKET: <base64_encoded_bucket_name>          # cinely-backups
  S3_ACCESS_KEY: <base64_encoded_access_key>
  S3_SECRET_KEY: <base64_encoded_secret_key>
